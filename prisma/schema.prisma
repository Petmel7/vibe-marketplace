generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters", "partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String               @id @db.Uuid
  email             String               @unique
  name              String?
  avatarUrl         String?              @map("avatar_url")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @map("updated_at")
  admin             AdminProfile?
  buyer             BuyerProfile?
  cart              Cart?
  orders            Order[]
  reviews           Review[]
  seller            SellerProfile?
  verifiedSellers   SellerProfile[]      @relation("VerifiedByUser")
  addresses         ShippingAddress[]
  stores            Store[]
  profile           UserProfile?
  assignedRoles     UserRoleAssignment[] @relation("AssignedByUser")
  roles             UserRoleAssignment[] @relation("UserRoles")
  viewedProducts    ViewedProduct[]
  wishlist          Wishlist?
  badgeRulesUpdated ProductBadgeRule[]   @relation("ProductBadgeRuleUpdatedBy")

  @@map("users")
}

model Store {
  id            String         @id @default(uuid()) @db.Uuid
  ownerId       String         @map("owner_id") @db.Uuid
  name          String
  slug          String         @unique
  description   String?
  logoUrl       String?        @map("logo_url")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @map("updated_at")
  bannerUrl     String?        @map("banner_url")
  isPrimary     Boolean        @default(false) @map("is_primary")
  orderItems    OrderItem[]
  products      Product[]
  owner         User           @relation(fields: [ownerId], references: [id], map: "stores_owner_id_user_fkey")
  sellerProfile SellerProfile? @relation("SellerStores", fields: [ownerId], references: [userId], map: "stores_owner_id_seller_fkey")

  @@index([ownerId], map: "stores_ownerId_idx")
  @@index([isActive], map: "stores_isActive_idx")
  @@map("stores")
}

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  image      String?    @map("image_url")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  parentId   String?    @map("parent_id")
  icon       String?
  hoverImage String?    @map("hover_image")
  position   Int        @default(0) @map("sort_order")
  level      Int        @default(1)
  isActive   Boolean    @default(true) @map("is_active")
  isVisible  Boolean    @default(true) @map("is_visible")
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children   Category[] @relation("CategoryHierarchy")
  products   Product[]

  @@index([parentId], map: "categories_parentId_idx")
  @@index([isActive], map: "categories_isActive_idx")
  @@index([position], map: "categories_position_idx")
  @@index([parentId, position], map: "categories_parentId_position_idx")
  @@map("categories")
}

model Product {
  id               String                   @id @default(uuid()) @db.Uuid
  storeId          String                   @map("store_id") @db.Uuid
  name             String
  description      String?
  price            Decimal                  @db.Decimal(10, 2)
  imageUrl         String?                  @map("image_url")
  isActive         Boolean                  @default(true) @map("is_active")
  sku              String?
  isHit            Boolean                  @default(false) @map("is_hit")
  isNew            Boolean                  @default(false) @map("is_new")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @map("updated_at")
  searchVector     Unsupported("tsvector")? @map("search_vector")
  categoryId       String?                  @map("category_id")
  status           ProductStatus            @default(DRAFT) @map("status")
  rejectionReason  String?                  @map("rejection_reason")
  publishedAt      DateTime?                @map("published_at")
  moderatedAt      DateTime?                @map("moderated_at")
  moderatedBy      String?                  @map("moderated_by")
  moderationReason String?                  @map("moderation_reason")
  badges           ProductBadge[]
  metrics          ProductMetrics?
  variants         ProductVariant[]
  images           ProductImage[]
  category         Category?                @relation(fields: [categoryId], references: [id])
  store            Store                    @relation(fields: [storeId], references: [id])
  reviews          Review[]
  viewedProducts   ViewedProduct[]
  wishlistItems    WishlistItem[]

  @@index([categoryId], map: "products_categoryId_idx")
  @@index([storeId], map: "products_storeId_idx")
  @@index([isActive], map: "products_isActive_idx")
  @@index([status])
  @@index([searchVector], map: "products_searchVector_idx", type: Gin)
  @@map("products")
}

model ProductBadge {
  id        String             @id @default(uuid()) @db.Uuid
  productId String             @map("product_id") @db.Uuid
  type      ProductBadgeType
  source    ProductBadgeSource
  score     Decimal?           @db.Decimal(10, 4)
  startsAt  DateTime?          @map("starts_at")
  endsAt    DateTime?          @map("ends_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  product   Product            @relation(fields: [productId], references: [id])

  @@index([type], map: "product_badges_type_idx")
  @@index([startsAt, endsAt], map: "product_badges_active_window_idx")
  @@index([productId, type], map: "product_badges_productId_type_idx")
  @@map("product_badges")
}

model ProductBadgeRule {
  id               String           @id @default(uuid()) @db.Uuid
  badgeType        ProductBadgeType @map("badge_type")
  minViews         Int              @default(0) @map("min_views")
  minWishlists     Int              @default(0) @map("min_wishlists")
  minSoldCount     Int              @default(0) @map("min_sold_count")
  minRevenueAmount Decimal          @default(0) @map("min_revenue_amount") @db.Decimal(12, 2)
  enabled          Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  updatedBy        String?          @map("updated_by") @db.Uuid
  updater          User?            @relation("ProductBadgeRuleUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([badgeType], map: "product_badge_rules_badge_type_key")
  @@index([badgeType], map: "product_badge_rules_badge_type_idx")
  @@index([enabled], map: "product_badge_rules_enabled_idx")
  @@index([updatedBy], map: "product_badge_rules_updated_by_idx")
  @@map("product_badge_rules")
}

model ProductMetrics {
  productId        String    @id @map("product_id") @db.Uuid
  viewCount        Int       @default(0) @map("view_count")
  wishlistCount    Int       @default(0) @map("wishlist_count")
  soldCount        Int       @default(0) @map("sold_count")
  revenueAmount    Decimal   @default(0) @map("revenue_amount") @db.Decimal(12, 2)
  ratingAvg        Decimal   @default(0) @map("rating_avg") @db.Decimal(3, 2)
  reviewCount      Int       @default(0) @map("review_count")
  hitScore         Decimal   @default(0) @map("hit_score") @db.Decimal(12, 4)
  lastCalculatedAt DateTime? @map("last_calculated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  product          Product   @relation(fields: [productId], references: [id])

  @@index([hitScore], map: "product_metrics_hitScore_idx")
  @@index([soldCount], map: "product_metrics_soldCount_idx")
  @@map("product_metrics")
}

model ProductImage {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  url         String
  storagePath String   @map("storage_path")
  altText     String?  @map("alt_text")
  position    Int      @default(0)
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId], map: "product_images_productId_idx")
  @@index([productId, position], map: "product_images_productId_position_idx")
  @@index([productId, isPrimary], map: "product_images_productId_isPrimary_idx")
  @@map("product_images")
}

model ProductVariant {
  id         String      @id @default(uuid()) @db.Uuid
  productId  String      @map("product_id") @db.Uuid
  sku        String      @unique
  size       String?
  color      String?
  price      Decimal?    @db.Decimal(10, 2)
  stock      Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @map("updated_at")
  cartItems  CartItem[]
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id])

  @@index([productId], map: "product_variants_productId_idx")
  @@map("product_variants")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  status            OrderStatus @default(pending)
  totalAmount       Decimal     @map("total_amount") @db.Decimal(10, 2)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @map("updated_at")
  shippingAddressId String?     @map("shipping_address_id") @db.Uuid
  note              String?
  items             OrderItem[]
  user              User        @relation(fields: [userId], references: [id])

  @@index([userId], map: "orders_userId_idx")
  @@index([status])
  @@index([shippingAddressId], map: "orders_shippingAddressId_idx")
  @@map("orders")
}

model OrderItem {
  id                  String                @id @default(uuid()) @db.Uuid
  orderId             String                @map("order_id") @db.Uuid
  variantId           String                @map("variant_id") @db.Uuid
  storeId             String                @map("store_id") @db.Uuid
  quantity            Int
  unitPrice           Decimal               @map("unit_price") @db.Decimal(10, 2)
  createdAt           DateTime              @default(now()) @map("created_at")
  productNameSnapshot String                @map("product_name_snapshot")
  variantSnapshot     String?               @map("variant_snapshot")
  imageSnapshot       String?               @map("image_snapshot")
  storeNameSnapshot   String                @map("store_name_snapshot")
  unitPriceSnapshot   Decimal               @map("unit_price_snapshot") @db.Decimal(10, 2)
  fulfillmentStatus   ItemFulfillmentStatus @default(PENDING) @map("fulfillment_status")
  order               Order                 @relation(fields: [orderId], references: [id])
  store               Store                 @relation(fields: [storeId], references: [id])
  variant             ProductVariant        @relation(fields: [variantId], references: [id])

  @@index([orderId], map: "order_items_orderId_idx")
  @@index([variantId], map: "order_items_variantId_idx")
  @@index([storeId], map: "order_items_storeId_idx")
  @@index([fulfillmentStatus], map: "order_items_fulfillmentStatus_idx")
  @@map("order_items")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @unique @map("user_id") @db.Uuid
  sessionId String?    @unique @map("session_id")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     CartItem[]
  user      User?      @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String         @map("cart_id") @db.Uuid
  variantId String         @map("variant_id") @db.Uuid
  quantity  Int            @default(1)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart      Cart           @relation(fields: [cartId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

model Wishlist {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String         @unique @map("user_id") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     WishlistItem[]
  user      User           @relation(fields: [userId], references: [id])

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wishlistId String   @map("wishlist_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product    Product  @relation(fields: [productId], references: [id])
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id])

  @@unique([wishlistId, productId])
  @@index([productId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model ViewedProduct {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id")
  productId String   @map("product_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@unique([sessionId, productId])
  @@map("viewed_products")
}

model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  phoneNumber String?  @map("phone_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "user_profiles_userId_idx")
  @@map("user_profiles")
}

model UserRoleAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  role       UserRole
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") @db.Uuid
  assigner   User?    @relation("AssignedByUser", fields: [assignedBy], references: [id])
  user       User     @relation("UserRoles", fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([userId], map: "user_role_assignments_userId_idx")
  @@index([role])
  @@map("user_role_assignments")
}

model BuyerProfile {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @unique @map("user_id") @db.Uuid
  defaultShippingAddressId String?  @map("default_shipping_address_id") @db.Uuid
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  user                     User     @relation(fields: [userId], references: [id])

  @@map("buyer_profiles")
}

model ShippingAddress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String?
  fullName  String   @map("full_name")
  phone     String
  country   String
  city      String
  region    String?
  street    String
  building  String
  apartment String?  @map("apartment")
  zipCode   String?  @map("zip_code")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "shipping_addresses_userId_idx")
  @@index([isDefault], map: "shipping_addresses_isDefault_idx")
  @@map("shipping_addresses")
}

model SellerProfile {
  id                 String                   @id @default(uuid()) @db.Uuid
  userId             String                   @unique @map("user_id") @db.Uuid
  verificationStatus SellerVerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?                @map("verified_at")
  verifiedBy         String?                  @map("verified_by") @db.Uuid
  businessName       String?                  @map("business_name")
  taxId              String?                  @map("tax_id")
  payoutAccountId    String?                  @map("payout_account_id")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  moderatedAt        DateTime?                @map("moderated_at")
  moderatedBy        String?                  @map("moderated_by")
  moderationReason   String?                  @map("moderation_reason")
  user               User                     @relation(fields: [userId], references: [id])
  verifier           User?                    @relation("VerifiedByUser", fields: [verifiedBy], references: [id])
  stores             Store[]                  @relation("SellerStores")

  @@index([verificationStatus], map: "seller_profiles_verificationStatus_idx")
  @@map("seller_profiles")
}

model AdminProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])

  @@map("admin_profiles")
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  confirmed
  processing
  cancelled
  refunded
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ProductBadgeType {
  NEW
  HIT
  FEATURED
}

enum ProductBadgeSource {
  SYSTEM
  ADMIN
}

enum ItemFulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum SellerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}
