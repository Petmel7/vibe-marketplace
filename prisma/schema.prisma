generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @db.Uuid
  email          String   @unique
  name           String?
  avatarUrl      String?  @map("avatar_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @map("updated_at")

  cart            Cart?
  orders          Order[]
  reviews         Review[]
  stores          Store[]
  viewedProducts  ViewedProduct[]
  wishlist        Wishlist?
  profile         UserProfile?
  roles           UserRoleAssignment[] @relation("UserRoles")
  assignedRoles   UserRoleAssignment[] @relation("AssignedByUser")
  buyer           BuyerProfile?
  seller          SellerProfile?
  verifiedSellers SellerProfile[]      @relation("VerifiedByUser")
  admin           AdminProfile?
  addresses       ShippingAddress[]

  @@map("users")
}

model Store {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?  @map("logo_url")
  bannerUrl   String?  @map("banner_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @map("updated_at")

  owner       User     @relation(fields: [ownerId], references: [id])
  products    Product[]
  orderItems  OrderItem[]

  @@index([ownerId], map: "stores_ownerId_idx")
  @@index([isActive], map: "stores_isActive_idx")
  @@map("stores")
}

model Category {
  id         String     @id @default(cuid())
  parentId   String?    @map("parent_id")
  name       String
  slug       String     @unique
  image      String?    @map("image_url")
  icon       String?
  hoverImage String?    @map("hover_image")
  order      Int        @default(0) @map("sort_order")
  level      Int        @default(1)
  isActive   Boolean    @default(true) @map("is_active")
  isVisible  Boolean    @default(true) @map("is_visible")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children   Category[] @relation("CategoryHierarchy")
  products   Product[]

  @@index([parentId], map: "categories_parentId_idx")
  @@index([order], map: "categories_order_idx")
  @@index([parentId, order], map: "categories_parentId_order_idx")
  @@map("categories")
}

model Product {
  id              String        @id @default(uuid()) @db.Uuid
  storeId         String        @map("store_id") @db.Uuid
  categoryId      String?       @map("category_id")
  name            String
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  imageUrl        String?       @map("image_url")
  isActive        Boolean       @default(true) @map("is_active")
  sku             String?
  isHit           Boolean       @default(false) @map("is_hit")
  isNew           Boolean       @default(false) @map("is_new")
  status          ProductStatus @default(DRAFT) @map("status")
  rejectionReason String?       @map("rejection_reason")
  publishedAt     DateTime?     @map("published_at")
  moderationReason String?      @map("moderation_reason")
  moderatedAt     DateTime?     @map("moderated_at")
  moderatedBy     String?       @map("moderated_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @map("updated_at")
  searchVector    Unsupported("tsvector")? @map("search_vector")

  store         Store    @relation(fields: [storeId], references: [id])
  category      Category? @relation(fields: [categoryId], references: [id])
  variants      ProductVariant[]
  reviews       Review[]
  viewedProducts ViewedProduct[]
  wishlistItems WishlistItem[]

  @@index([categoryId], map: "products_categoryId_idx")
  @@index([storeId], map: "products_storeId_idx")
  @@index([isActive], map: "products_isActive_idx")
  @@index([status], map: "products_status_idx")
  @@index([searchVector], map: "products_searchVector_idx", type: Gin)
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  sku        String   @unique
  size       String?
  color      String?
  price      Decimal? @db.Decimal(10, 2)
  stock      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @map("updated_at")

  product    Product  @relation(fields: [productId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId], map: "product_variants_productId_idx")
  @@map("product_variants")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  status            OrderStatus @default(pending)
  totalAmount       Decimal     @map("total_amount") @db.Decimal(10, 2)
  shippingAddressId String?     @map("shipping_address_id") @db.Uuid
  note              String?
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @map("updated_at")

  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]

  @@index([userId], map: "orders_userId_idx")
  @@index([status])
  @@index([shippingAddressId], map: "orders_shippingAddressId_idx")
  @@map("orders")
}

model OrderItem {
  id                  String                @id @default(uuid()) @db.Uuid
  orderId             String                @map("order_id") @db.Uuid
  variantId           String                @map("variant_id") @db.Uuid
  storeId             String                @map("store_id") @db.Uuid
  quantity            Int
  unitPrice           Decimal               @map("unit_price") @db.Decimal(10, 2)
  productNameSnapshot String                @map("product_name_snapshot")
  variantSnapshot     String?               @map("variant_snapshot")
  imageSnapshot       String?               @map("image_snapshot")
  storeNameSnapshot   String                @map("store_name_snapshot")
  unitPriceSnapshot   Decimal               @map("unit_price_snapshot") @db.Decimal(10, 2)
  fulfillmentStatus   ItemFulfillmentStatus @default(PENDING) @map("fulfillment_status")
  createdAt           DateTime              @default(now()) @map("created_at")

  order      Order          @relation(fields: [orderId], references: [id])
  store      Store          @relation(fields: [storeId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId], map: "order_items_orderId_idx")
  @@index([variantId], map: "order_items_variantId_idx")
  @@index([storeId], map: "order_items_storeId_idx")
  @@index([fulfillmentStatus], map: "order_items_fulfillmentStatus_idx")
  @@map("order_items")
}

model Cart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @unique @map("user_id") @db.Uuid
  sessionId String?  @unique @map("session_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User?    @relation(fields: [userId], references: [id])
  items     CartItem[]

  @@index([sessionId])
  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  cart      Cart           @relation(fields: [cartId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User     @relation(fields: [userId], references: [id])
  items     WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wishlistId String   @map("wishlist_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  wishlist   Wishlist @relation(fields: [wishlistId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([wishlistId, productId])
  @@index([productId])
  @@index([wishlistId])
  @@map("wishlist_items")
}

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model ViewedProduct {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id")
  productId String   @map("product_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)

  product   Product  @relation(fields: [productId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  // Full unique constraints; NULL values are distinct by default, so guest
  // rows (user_id IS NULL) and authenticated rows (session_id IS NULL) coexist
  // correctly. A CHECK constraint at the DB level still enforces that exactly
  // one of (user_id, session_id) is non-null per row.
  @@unique([userId, productId])
  @@unique([sessionId, productId])
  @@map("viewed_products")
}

enum OrderStatus {
  pending
  confirmed
  paid
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ItemFulfillmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum SellerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  phoneNumber String?  @map("phone_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "user_profiles_userId_idx")
  @@map("user_profiles")
}

model UserRoleAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  role       UserRole
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") @db.Uuid

  user       User     @relation("UserRoles", fields: [userId], references: [id])
  assigner   User?    @relation("AssignedByUser", fields: [assignedBy], references: [id])

  @@unique([userId, role])
  @@index([userId], map: "user_role_assignments_userId_idx")
  @@index([role], map: "user_role_assignments_role_idx")
  @@map("user_role_assignments")
}

model BuyerProfile {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @unique @map("user_id") @db.Uuid
  defaultShippingAddressId String?  @map("default_shipping_address_id") @db.Uuid
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user                     User     @relation(fields: [userId], references: [id])

  @@map("buyer_profiles")
}

model ShippingAddress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String?
  fullName  String   @map("full_name")
  phone     String
  country   String
  city      String
  region    String?
  street    String
  building  String
  apartment String?  @map("apartment")
  zipCode   String?  @map("zip_code")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "shipping_addresses_userId_idx")
  @@index([isDefault], map: "shipping_addresses_isDefault_idx")
  @@map("shipping_addresses")
}

model SellerProfile {
  id                 String                   @id @default(uuid()) @db.Uuid
  userId             String                   @unique @map("user_id") @db.Uuid
  verificationStatus SellerVerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?                @map("verified_at")
  verifiedBy         String?                  @map("verified_by") @db.Uuid
  businessName       String?                  @map("business_name")
  taxId              String?                  @map("tax_id")
  payoutAccountId    String?                  @map("payout_account_id")
  moderationReason   String?                  @map("moderation_reason")
  moderatedAt        DateTime?                @map("moderated_at")
  moderatedBy        String?                  @map("moderated_by")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  user               User                     @relation(fields: [userId], references: [id])
  verifier           User?                    @relation("VerifiedByUser", fields: [verifiedBy], references: [id])

  @@index([verificationStatus], map: "seller_profiles_verificationStatus_idx")
  @@map("seller_profiles")
}

model AdminProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("admin_profiles")
}
