generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters", "partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @db.Uuid
  email                String                @unique
  name                 String?
  avatarUrl            String?               @map("avatar_url")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @map("updated_at")
  admin                AdminProfile?
  buyer                BuyerProfile?
  cart                 Cart?
  orders               Order[]
  reviews              Review[]
  seller               SellerProfile?
  verifiedSellers      SellerProfile[]       @relation("VerifiedByUser")
  addresses            ShippingAddress[]
  stores               Store[]
  profile              UserProfile?
  assignedRoles        UserRoleAssignment[]  @relation("AssignedByUser")
  roles                UserRoleAssignment[]  @relation("UserRoles")
  viewedProducts       ViewedProduct[]
  wishlist             Wishlist?
  badgeRulesUpdated    ProductBadgeRule[]    @relation("ProductBadgeRuleUpdatedBy")
  emailEvents          EmailEvent[]
  emailLogs            EmailLog[]
  notifications        Notification[]
  moderatedReviews     Review[]              @relation("ReviewModeratedBy")
  reportedAbuseReports AbuseReport[]         @relation("AbuseReportReporter")
  assignedAbuseReports AbuseReport[]         @relation("AbuseReportAssignedAdmin")
  resolvedAbuseReports AbuseReport[]         @relation("AbuseReportResolvedBy")
  abuseReportActions   AbuseReportAction[]   @relation("AbuseReportActionAdmin")
  abuseReportEvidence  AbuseReportEvidence[] @relation("AbuseReportEvidenceUploadedBy")
  openedDisputes       Dispute[]             @relation("DisputeOpenedBy")
  respondedDisputes    Dispute[]             @relation("DisputeRespondent")
  resolvedDisputes     Dispute[]             @relation("DisputeResolvedBy")
  disputeMessages      DisputeMessage[]      @relation("DisputeMessageSender")
  disputeEvidence      DisputeEvidence[]     @relation("DisputeEvidenceUploadedBy")
  riskProfile          RiskProfile?          @relation("UserRiskProfile")
  riskSignals          RiskSignal[]          @relation("UserRiskSignals")
  platformCommissions  PlatformCommission[]  @relation("PlatformCommissionSeller")
  sellerLedgerEntries  SellerLedgerEntry[]   @relation("SellerLedgerEntrySeller")
  sellerBalances       SellerBalance[]       @relation("SellerBalanceSeller")
  payouts              Payout[]              @relation("PayoutSeller")
  createdPayouts       Payout[]              @relation("PayoutCreatedBy")
  createdPromotions    Promotion[]           @relation("PromotionCreatedBy")
  promotionUsages      PromotionUsage[]

  @@map("users")
}

model Store {
  id                  String               @id @default(uuid()) @db.Uuid
  ownerId             String               @map("owner_id") @db.Uuid
  name                String
  slug                String               @unique
  description         String?
  logoUrl             String?              @map("logo_url")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @map("updated_at")
  bannerUrl           String?              @map("banner_url")
  isPrimary           Boolean              @default(false) @map("is_primary")
  orderItems          OrderItem[]
  products            Product[]
  owner               User                 @relation(fields: [ownerId], references: [id], map: "stores_owner_id_user_fkey")
  sellerProfile       SellerProfile?       @relation("SellerStores", fields: [ownerId], references: [userId], map: "stores_owner_id_seller_fkey")
  disputes            Dispute[]
  riskProfile         RiskProfile?         @relation("StoreRiskProfile")
  riskSignals         RiskSignal[]         @relation("StoreRiskSignals")
  platformCommissions PlatformCommission[]
  sellerLedgerEntries SellerLedgerEntry[]
  sellerBalance       SellerBalance?
  payouts             Payout[]
  promotions          Promotion[]

  @@index([ownerId], map: "stores_ownerId_idx")
  @@index([isActive], map: "stores_isActive_idx")
  @@map("stores")
}

model Category {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  image      String?    @map("image_url")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  parentId   String?    @map("parent_id")
  icon       String?
  hoverImage String?    @map("hover_image")
  position   Int        @default(0) @map("sort_order")
  level      Int        @default(1)
  isActive   Boolean    @default(true) @map("is_active")
  isVisible  Boolean    @default(true) @map("is_visible")
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children   Category[] @relation("CategoryHierarchy")
  products   Product[]

  @@index([parentId], map: "categories_parentId_idx")
  @@index([isActive], map: "categories_isActive_idx")
  @@index([position], map: "categories_position_idx")
  @@index([parentId, position], map: "categories_parentId_position_idx")
  @@index([parentId, isActive, position], map: "categories_parentId_isActive_position_idx")
  @@map("categories")
}

model Product {
  id               String                   @id @default(uuid()) @db.Uuid
  storeId          String                   @map("store_id") @db.Uuid
  name             String
  description      String?
  price            Decimal                  @db.Decimal(10, 2)
  imageUrl         String?                  @map("image_url")
  isActive         Boolean                  @default(true) @map("is_active")
  sku              String?
  isHit            Boolean                  @default(false) @map("is_hit")
  isNew            Boolean                  @default(false) @map("is_new")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @map("updated_at")
  searchVector     Unsupported("tsvector")? @map("search_vector")
  categoryId       String?                  @map("category_id")
  status           ProductStatus            @default(DRAFT) @map("status")
  rejectionReason  String?                  @map("rejection_reason")
  publishedAt      DateTime?                @map("published_at")
  moderatedAt      DateTime?                @map("moderated_at")
  moderatedBy      String?                  @map("moderated_by")
  moderationReason String?                  @map("moderation_reason")
  badges           ProductBadge[]
  metrics          ProductMetrics?
  ratingSummary    ProductRatingSummary?
  variants         ProductVariant[]
  images           ProductImage[]
  category         Category?                @relation(fields: [categoryId], references: [id])
  store            Store                    @relation(fields: [storeId], references: [id])
  reviews          Review[]
  viewedProducts   ViewedProduct[]
  wishlistItems    WishlistItem[]

  @@index([categoryId], map: "products_categoryId_idx")
  @@index([storeId], map: "products_storeId_idx")
  @@index([isActive], map: "products_isActive_idx")
  @@index([price], map: "products_price_idx")
  @@index([publishedAt], map: "products_publishedAt_idx")
  @@index([status])
  @@index([status, isActive], map: "products_status_isActive_idx")
  @@index([categoryId, status], map: "products_categoryId_status_idx")
  @@index([storeId, status], map: "products_storeId_status_idx")
  @@index([searchVector], map: "products_searchVector_idx", type: Gin)
  @@map("products")
}

model ProductBadge {
  id        String             @id @default(uuid()) @db.Uuid
  productId String             @map("product_id") @db.Uuid
  type      ProductBadgeType
  source    ProductBadgeSource
  score     Decimal?           @db.Decimal(10, 4)
  startsAt  DateTime?          @map("starts_at")
  endsAt    DateTime?          @map("ends_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  product   Product            @relation(fields: [productId], references: [id])

  @@index([type], map: "product_badges_type_idx")
  @@index([startsAt, endsAt], map: "product_badges_active_window_idx")
  @@index([productId, type], map: "product_badges_productId_type_idx")
  @@map("product_badges")
}

model ProductBadgeRule {
  id               String           @id @default(uuid()) @db.Uuid
  badgeType        ProductBadgeType @map("badge_type")
  minViews         Int              @default(0) @map("min_views")
  minWishlists     Int              @default(0) @map("min_wishlists")
  minSoldCount     Int              @default(0) @map("min_sold_count")
  minRevenueAmount Decimal          @default(0) @map("min_revenue_amount") @db.Decimal(12, 2)
  enabled          Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  updatedBy        String?          @map("updated_by") @db.Uuid
  updater          User?            @relation("ProductBadgeRuleUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([badgeType], map: "product_badge_rules_badge_type_key")
  @@index([badgeType], map: "product_badge_rules_badge_type_idx")
  @@index([enabled], map: "product_badge_rules_enabled_idx")
  @@index([updatedBy], map: "product_badge_rules_updated_by_idx")
  @@map("product_badge_rules")
}

model ProductMetrics {
  productId        String    @id @map("product_id") @db.Uuid
  viewCount        Int       @default(0) @map("view_count")
  wishlistCount    Int       @default(0) @map("wishlist_count")
  soldCount        Int       @default(0) @map("sold_count")
  revenueAmount    Decimal   @default(0) @map("revenue_amount") @db.Decimal(12, 2)
  ratingAvg        Decimal   @default(0) @map("rating_avg") @db.Decimal(3, 2)
  reviewCount      Int       @default(0) @map("review_count")
  hitScore         Decimal   @default(0) @map("hit_score") @db.Decimal(12, 4)
  lastCalculatedAt DateTime? @map("last_calculated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  product          Product   @relation(fields: [productId], references: [id])

  @@index([hitScore], map: "product_metrics_hitScore_idx")
  @@index([soldCount], map: "product_metrics_soldCount_idx")
  @@index([wishlistCount], map: "product_metrics_wishlistCount_idx")
  @@index([viewCount], map: "product_metrics_viewCount_idx")
  @@map("product_metrics")
}

model ProductImage {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  url         String
  storagePath String   @map("storage_path")
  altText     String?  @map("alt_text")
  position    Int      @default(0)
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId], map: "product_images_productId_idx")
  @@index([productId, position], map: "product_images_productId_position_idx")
  @@index([productId, isPrimary], map: "product_images_productId_isPrimary_idx")
  @@map("product_images")
}

model ProductVariant {
  id         String      @id @default(uuid()) @db.Uuid
  productId  String      @map("product_id") @db.Uuid
  sku        String      @unique
  size       String?
  color      String?
  price      Decimal?    @db.Decimal(10, 2)
  stock      Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @map("updated_at")
  cartItems  CartItem[]
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id])

  @@index([productId], map: "product_variants_productId_idx")
  @@index([productId, stock], map: "product_variants_productId_stock_idx")
  @@map("product_variants")
}

model Order {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @map("user_id") @db.Uuid
  status            OrderStatus      @default(pending)
  totalAmount       Decimal          @map("total_amount") @db.Decimal(10, 2)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @map("updated_at")
  shippingAddressId String?          @map("shipping_address_id") @db.Uuid
  note              String?
  items             OrderItem[]
  payments          Payment[]
  user              User             @relation(fields: [userId], references: [id])
  disputes          Dispute[]
  promotionUsages   PromotionUsage[]
  orderPromotion    OrderPromotion?

  @@index([userId], map: "orders_userId_idx")
  @@index([status])
  @@index([shippingAddressId], map: "orders_shippingAddressId_idx")
  @@map("orders")
}

model OrderItem {
  id                  String                @id @default(uuid()) @db.Uuid
  orderId             String                @map("order_id") @db.Uuid
  variantId           String                @map("variant_id") @db.Uuid
  storeId             String                @map("store_id") @db.Uuid
  quantity            Int
  unitPrice           Decimal               @map("unit_price") @db.Decimal(10, 2)
  createdAt           DateTime              @default(now()) @map("created_at")
  productNameSnapshot String                @map("product_name_snapshot")
  variantSnapshot     String?               @map("variant_snapshot")
  imageSnapshot       String?               @map("image_snapshot")
  storeNameSnapshot   String                @map("store_name_snapshot")
  unitPriceSnapshot   Decimal               @map("unit_price_snapshot") @db.Decimal(10, 2)
  fulfillmentStatus   ItemFulfillmentStatus @default(PENDING) @map("fulfillment_status")
  refunds             Refund[]
  review              Review?
  order               Order                 @relation(fields: [orderId], references: [id])
  store               Store                 @relation(fields: [storeId], references: [id])
  variant             ProductVariant        @relation(fields: [variantId], references: [id])
  disputes            Dispute[]
  platformCommission  PlatformCommission?
  sellerLedgerEntries SellerLedgerEntry[]

  @@index([orderId], map: "order_items_orderId_idx")
  @@index([variantId], map: "order_items_variantId_idx")
  @@index([storeId], map: "order_items_storeId_idx")
  @@index([fulfillmentStatus], map: "order_items_fulfillmentStatus_idx")
  @@map("order_items")
}

model Payment {
  id                String                @id @default(uuid()) @db.Uuid
  orderId           String                @map("order_id") @db.Uuid
  provider          PaymentProvider
  providerPaymentId String?               @map("provider_payment_id")
  status            PaymentStatus         @default(PENDING)
  method            PaymentMethod
  amount            Decimal               @db.Decimal(12, 2)
  currency          String                @db.VarChar(3)
  checkoutUrl       String?               @map("checkout_url")
  failureReason     String?               @map("failure_reason")
  paidAt            DateTime?             @map("paid_at")
  expiresAt         DateTime?             @map("expires_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  attempts          PaymentAttempt[]
  order             Order                 @relation(fields: [orderId], references: [id])
  refunds           Refund[]
  webhookEvents     PaymentWebhookEvent[]

  @@index([orderId], map: "payments_order_id_idx")
  @@index([status], map: "payments_status_idx")
  @@index([provider], map: "payments_provider_idx")
  @@index([providerPaymentId], map: "payments_provider_payment_id_idx")
  @@map("payments")
}

model PaymentAttempt {
  id              String          @id @default(uuid()) @db.Uuid
  paymentId       String          @map("payment_id") @db.Uuid
  provider        PaymentProvider
  status          PaymentStatus
  amount          Decimal         @db.Decimal(12, 2)
  requestPayload  Json            @map("request_payload")
  responsePayload Json?           @map("response_payload")
  errorMessage    String?         @map("error_message")
  createdAt       DateTime        @default(now()) @map("created_at")
  payment         Payment         @relation(fields: [paymentId], references: [id])

  @@index([paymentId], map: "payment_attempts_payment_id_idx")
  @@map("payment_attempts")
}

model PaymentWebhookEvent {
  id              String          @id @default(uuid()) @db.Uuid
  paymentId       String?         @map("payment_id") @db.Uuid
  provider        PaymentProvider
  providerEventId String          @map("provider_event_id")
  eventType       String          @map("event_type")
  payload         Json
  signatureValid  Boolean         @default(false) @map("signature_valid")
  processedAt     DateTime?       @map("processed_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  payment         Payment?        @relation(fields: [paymentId], references: [id])

  @@unique([provider, providerEventId], map: "payment_webhook_events_provider_provider_event_id_key")
  @@index([paymentId], map: "payment_webhook_events_payment_id_idx")
  @@index([providerEventId], map: "payment_webhook_events_provider_event_id_idx")
  @@map("payment_webhook_events")
}

model Refund {
  id               String       @id @default(uuid()) @db.Uuid
  paymentId        String       @map("payment_id") @db.Uuid
  orderItemId      String?      @map("order_item_id") @db.Uuid
  providerRefundId String?      @map("provider_refund_id")
  status           RefundStatus @default(PENDING)
  amount           Decimal      @db.Decimal(12, 2)
  reason           String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  orderItem        OrderItem?   @relation(fields: [orderItemId], references: [id])
  payment          Payment      @relation(fields: [paymentId], references: [id])

  @@index([paymentId], map: "refunds_payment_id_idx")
  @@index([status], map: "refunds_status_idx")
  @@index([orderItemId], map: "refunds_order_item_id_idx")
  @@map("refunds")
}

model PlatformCommission {
  id               String    @id @default(uuid()) @db.Uuid
  orderItemId      String    @unique(map: "platform_commissions_order_item_id_key") @map("order_item_id") @db.Uuid
  storeId          String    @map("store_id") @db.Uuid
  sellerId         String    @map("seller_id") @db.Uuid
  grossAmount      Decimal   @map("gross_amount") @db.Decimal(12, 2)
  commissionRate   Decimal   @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal   @map("commission_amount") @db.Decimal(12, 2)
  sellerNetAmount  Decimal   @map("seller_net_amount") @db.Decimal(12, 2)
  currency         String    @db.VarChar(3)
  createdAt        DateTime  @default(now()) @map("created_at")
  orderItem        OrderItem @relation(fields: [orderItemId], references: [id])
  store            Store     @relation(fields: [storeId], references: [id])
  seller           User      @relation("PlatformCommissionSeller", fields: [sellerId], references: [id])

  @@index([storeId], map: "platform_commissions_store_id_idx")
  @@index([sellerId], map: "platform_commissions_seller_id_idx")
  @@index([createdAt], map: "platform_commissions_created_at_idx")
  @@map("platform_commissions")
}

model SellerLedgerEntry {
  id          String                  @id @default(uuid()) @db.Uuid
  storeId     String                  @map("store_id") @db.Uuid
  sellerId    String                  @map("seller_id") @db.Uuid
  orderItemId String?                 @map("order_item_id") @db.Uuid
  payoutId    String?                 @map("payout_id") @db.Uuid
  type        SellerLedgerEntryType
  status      SellerLedgerEntryStatus
  amount      Decimal                 @db.Decimal(12, 2)
  currency    String                  @db.VarChar(3)
  description String
  availableAt DateTime?               @map("available_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  orderItem   OrderItem?              @relation(fields: [orderItemId], references: [id])
  payout      Payout?                 @relation(fields: [payoutId], references: [id])
  payoutItem  PayoutItem?
  seller      User                    @relation("SellerLedgerEntrySeller", fields: [sellerId], references: [id])
  store       Store                   @relation(fields: [storeId], references: [id])

  @@index([storeId], map: "seller_ledger_entries_store_id_idx")
  @@index([sellerId], map: "seller_ledger_entries_seller_id_idx")
  @@index([orderItemId], map: "seller_ledger_entries_order_item_id_idx")
  @@index([payoutId], map: "seller_ledger_entries_payout_id_idx")
  @@index([type], map: "seller_ledger_entries_type_idx")
  @@index([status], map: "seller_ledger_entries_status_idx")
  @@index([availableAt], map: "seller_ledger_entries_available_at_idx")
  @@index([createdAt], map: "seller_ledger_entries_created_at_idx")
  @@map("seller_ledger_entries")
}

model SellerBalance {
  id              String   @id @default(uuid()) @db.Uuid
  storeId         String   @unique(map: "seller_balances_store_id_key") @map("store_id") @db.Uuid
  sellerId        String   @map("seller_id") @db.Uuid
  pendingAmount   Decimal  @default(0) @map("pending_amount") @db.Decimal(12, 2)
  availableAmount Decimal  @default(0) @map("available_amount") @db.Decimal(12, 2)
  paidOutAmount   Decimal  @default(0) @map("paid_out_amount") @db.Decimal(12, 2)
  currency        String   @db.VarChar(3)
  updatedAt       DateTime @updatedAt @map("updated_at")
  seller          User     @relation("SellerBalanceSeller", fields: [sellerId], references: [id])
  store           Store    @relation(fields: [storeId], references: [id])

  @@index([sellerId], map: "seller_balances_seller_id_idx")
  @@map("seller_balances")
}

model Payout {
  id            String              @id @default(uuid()) @db.Uuid
  storeId       String              @map("store_id") @db.Uuid
  sellerId      String              @map("seller_id") @db.Uuid
  amount        Decimal             @db.Decimal(12, 2)
  currency      String              @db.VarChar(3)
  method        PayoutMethod
  status        PayoutStatus        @default(PENDING)
  reference     String?
  adminNote     String?             @map("admin_note")
  createdById   String              @map("created_by_id") @db.Uuid
  paidAt        DateTime?           @map("paid_at")
  failedAt      DateTime?           @map("failed_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  createdBy     User                @relation("PayoutCreatedBy", fields: [createdById], references: [id])
  items         PayoutItem[]
  ledgerEntries SellerLedgerEntry[]
  seller        User                @relation("PayoutSeller", fields: [sellerId], references: [id])
  store         Store               @relation(fields: [storeId], references: [id])

  @@index([storeId], map: "payouts_store_id_idx")
  @@index([sellerId], map: "payouts_seller_id_idx")
  @@index([status], map: "payouts_status_idx")
  @@index([createdById], map: "payouts_created_by_id_idx")
  @@index([createdAt], map: "payouts_created_at_idx")
  @@map("payouts")
}

model PayoutItem {
  id            String            @id @default(uuid()) @db.Uuid
  payoutId      String            @map("payout_id") @db.Uuid
  ledgerEntryId String            @unique(map: "payout_items_ledger_entry_id_key") @map("ledger_entry_id") @db.Uuid
  amount        Decimal           @db.Decimal(12, 2)
  createdAt     DateTime          @default(now()) @map("created_at")
  ledgerEntry   SellerLedgerEntry @relation(fields: [ledgerEntryId], references: [id])
  payout        Payout            @relation(fields: [payoutId], references: [id])

  @@index([payoutId], map: "payout_items_payout_id_idx")
  @@index([createdAt], map: "payout_items_created_at_idx")
  @@map("payout_items")
}

model Promotion {
  id                String                @id @default(uuid()) @db.Uuid
  code              String                @unique
  name              String
  description       String?
  ownerType         PromotionOwnerType    @default(MARKETPLACE) @map("owner_type")
  storeId           String?               @map("store_id") @db.Uuid
  type              PromotionType
  discountType      PromotionDiscountType @map("discount_type")
  discountValue     Decimal               @map("discount_value") @db.Decimal(12, 2)
  minOrderAmount    Decimal?              @map("min_order_amount") @db.Decimal(12, 2)
  maxDiscountAmount Decimal?              @map("max_discount_amount") @db.Decimal(12, 2)
  usageLimit        Int?                  @map("usage_limit")
  usageLimitPerUser Int?                  @map("usage_limit_per_user")
  startsAt          DateTime              @map("starts_at")
  endsAt            DateTime?             @map("ends_at")
  isActive          Boolean               @default(true) @map("is_active")
  createdById       String                @map("created_by_id") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  createdBy         User                  @relation("PromotionCreatedBy", fields: [createdById], references: [id])
  store             Store?                @relation(fields: [storeId], references: [id])
  usages            PromotionUsage[]
  orderPromotions   OrderPromotion[]
  targets           PromotionTarget[]

  @@index([ownerType], map: "promotions_owner_type_idx")
  @@index([storeId], map: "promotions_store_id_idx")
  @@index([isActive], map: "promotions_is_active_idx")
  @@index([startsAt], map: "promotions_starts_at_idx")
  @@index([endsAt], map: "promotions_ends_at_idx")
  @@index([createdById], map: "promotions_created_by_id_idx")
  @@map("promotions")
}

model PromotionTarget {
